generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECEPTION
  SPECIALIST
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum ProductCategory {
  PREPARATION
  COSMETIC
}

enum UnitType {
  UNIT
  ML
  AMPULE
  BOTOX_UNIT
}

enum ConsumptionKind {
  APPOINTMENT
  INTERNAL
  SALE
}

enum PaymentMethod {
  CASH
  CARD
  VOUCHER
}

model User {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role         Role     @default(SPECIALIST)
  login        String   @unique
  name         String
  email        String?  @unique
  passwordHash String
  phone        String?
  specialistCode Int?
  isVisible    Boolean  @default(true)
  isAvailable  Boolean  @default(false)
  avatarUrl    String?
  jobTitle     String?
  sourceProfileUrl String?

  // For specialist settlements (percentage share of appointment final price)
  payoutPercent Int @default(50)

  appointments        Appointment[] @relation("AppointmentSpecialist")
  createdConsumptions Consumption[] @relation("ConsumptionCreator")
  specialistConsumptions Consumption[] @relation("ConsumptionSpecialist")
  retailSales         RetailSale[] @relation("RetailSaleSeller")
  auditLogs           AuditLog[]

  @@index([role])
  @@index([specialistCode])
}


model Patient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  phone     String?
  email     String?
  note      String?

  appointments Appointment[]
  retailSales  RetailSale[]

  @@index([name])
  @@index([phone])
}

model Service {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  category    String?
  description String?
  durationMin Int    @default(30)

  // Suggested pricing (grosze)
  priceFrom      Int?
  priceSuggested Int?

  suggestedProducts ServiceSuggestedProduct[]
  appointments      Appointment[]

  @@index([name])
  @@index([category])
}

model ServiceSuggestedProduct {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  // default quantity for this service suggestion
  quantity  Decimal  @db.Decimal(12,2)
  unit      UnitType @default(UNIT)

  @@unique([serviceId, productId])
  @@index([serviceId])
}

model Product {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category  ProductCategory
  name      String
  sku       String?
  unit      UnitType @default(UNIT)
  manufacturer String?
  catalogCategory String?

  purchasePrice Int? // grosze
  salePrice     Int? // grosze
  isActive      Boolean @default(true)

  stocks        Stock[]
  lots          ProductLot[]
  consumptions  Consumption[]
  saleItems     RetailSaleItem[]
  serviceSuggestions ServiceSuggestedProduct[]

  @@index([category])
  @@index([name])
  @@index([sku])
  @@index([manufacturer])
  @@index([catalogCategory])
}

model Warehouse {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  parentId  String?
  parent    Warehouse? @relation("WarehouseTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Warehouse[] @relation("WarehouseTree")

  stocks    Stock[]
  lots      ProductLot[]
  consumptions Consumption[]

  @@index([parentId])
  @@index([name])
}

model Stock {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  quantity    Decimal  @db.Decimal(14,2) @default(0)

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@index([productId])
}

model ProductLot {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  batchNumber String
  expiryDate  DateTime
  quantity    Decimal   @db.Decimal(14,2) @default(0)
  purchasePrice Int?
  salePrice     Int?
  status      String?
  location    String?
  note        String?

  @@index([productId])
  @@index([warehouseId])
  @@index([expiryDate])
  @@index([batchNumber])
}

model Appointment {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  specialistId String
  specialist   User     @relation("AppointmentSpecialist", fields: [specialistId], references: [id], onDelete: Restrict)

  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  startsAt    DateTime
  endsAt      DateTime

  status      AppointmentStatus @default(SCHEDULED)

  // pricing (grosze)
  priceEstimate Int?
  priceFinal    Int?

  note        String?

  consumptions Consumption[]
  payments    Payment[]

  @@index([specialistId, startsAt])
  @@index([patientId, startsAt])
  @@index([status])
}

model Consumption {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  kind        ConsumptionKind @default(APPOINTMENT)

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  specialistId String?
  specialist   User? @relation("ConsumptionSpecialist", fields: [specialistId], references: [id], onDelete: SetNull)

  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  quantity    Decimal  @db.Decimal(14,2)

  createdById String
  createdBy   User     @relation("ConsumptionCreator", fields: [createdById], references: [id], onDelete: Restrict)

  note        String?

  @@index([appointmentId])
  @@index([productId])
  @@index([createdById])
}

model RetailSale {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  soldById  String
  soldBy    User     @relation("RetailSaleSeller", fields: [soldById], references: [id], onDelete: Restrict)

  items     RetailSaleItem[]
  payments  Payment[]

  note      String?

  @@index([soldById, createdAt])
}

model RetailSaleItem {
  id        String   @id @default(cuid())
  saleId    String
  sale      RetailSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity  Decimal @db.Decimal(14,2)
  unitPrice Int? // grosze
  total     Int? // grosze

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  method       PaymentMethod
  amount       Int // grosze

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  retailSaleId  String?
  retailSale    RetailSale? @relation(fields: [retailSaleId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([retailSaleId])
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  actorId   String
  actor     User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  action    String
  entity    String
  entityId  String?
  data      Json?

  @@index([actorId, createdAt])
  @@index([entity, createdAt])
}
