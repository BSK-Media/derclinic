generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECEPTION
  SPECIALIST
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum ProductCategory {
  PREPARATION
  COSMETIC
}

enum UnitType {
  UNIT
  ML
  MG
  G
  AMPULE
  BOTOX_UNIT
}

enum ConsumptionKind {
  APPOINTMENT
  INTERNAL
  SALE
}

enum PaymentMethod {
  CASH
  CARD
  VOUCHER
}

enum ConsumptionStatus {
  APPLIED
  PENDING
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role             Role    @default(SPECIALIST)
  login            String  @unique
  name             String
  email            String? @unique
  passwordHash     String
  phone            String?
  specialistCode   Int?
  isVisible        Boolean @default(true)
  isAvailable      Boolean @default(false)
  avatarUrl        String?
  jobTitle         String?
  location         String?
  specialization   String?
  sourceProfileUrl String?

  // Indywidualny dostęp do sekcji lewego menu. Null = domyślny zakres pracownika.
  sidebarPermissions Json?

  // For specialist settlements (percentage share of appointment final price)
  payoutPercent Int @default(50)

  // Domyślna stawka kwotowa za pojedynczy zabieg (grosze); nadpisywana stawkami per zabieg
  baseRate Int?

  appointments           Appointment[]           @relation("AppointmentSpecialist")
  createdConsumptions    Consumption[]           @relation("ConsumptionCreator")
  specialistConsumptions Consumption[]           @relation("ConsumptionSpecialist")
  reviewedConsumptions   Consumption[]           @relation("ConsumptionReviewer")
  retailSales            RetailSale[]            @relation("RetailSaleSeller")
  auditLogs              AuditLog[]
  serviceRates           SpecialistServiceRate[]
  warehouseAssignments   SpecialistWarehouse[]
  approvedAppointments   Appointment[]           @relation("AppointmentApprover")
  deletedAppointments    Appointment[]           @relation("AppointmentDeleter")
  assignedServices       SpecialistService[]
  workDays               SpecialistWorkDay[]
  timeOffs               SpecialistTimeOff[]

  @@index([role])
  @@index([specialistCode])
}

model Patient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String
  phone String?
  email String?
  note  String?

  appointments Appointment[]
  retailSales  RetailSale[]

  @@index([name])
  @@index([phone])
}

model Service {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  category    String?
  description String?
  durationMin Int     @default(30)

  // Jedna obowiązująca cena usługi (grosze). Pole korzysta z istniejącej
  // kolumny priceSuggested, aby zachować dane podczas wdrożenia.
  price Int? @map("priceSuggested")

  // Historyczna kolumna pozostaje w bazie wyłącznie dla bezpiecznej zgodności
  // wdrożeniowej i nie jest dostępna w Prisma Client ani w aplikacji.
  legacyPriceFrom Int? @map("priceFrom") @ignore

  suggestedProducts     ServiceSuggestedProduct[]
  appointments          Appointment[]
  specialistRates       SpecialistServiceRate[]
  specialistAssignments SpecialistService[]

  @@index([name])
  @@index([category])
}

model ServiceSuggestedProduct {
  id        String  @id @default(cuid())
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  // default quantity for this service suggestion
  quantity Decimal  @db.Decimal(12, 2)
  unit     UnitType @default(UNIT)

  @@unique([serviceId, productId])
  @@index([serviceId])
}

model SpecialistServiceRate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specialistId String
  specialist   User   @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Stawka kwotowa pracownika za ten zabieg (grosze)
  amount Int

  @@unique([specialistId, serviceId])
  @@index([specialistId])
  @@index([serviceId])
}

// Usługi rzeczywiście wykonywane przez danego pracownika.
// To osobna relacja od stawki, ponieważ pusta stawka nie oznacza braku przypisania.
model SpecialistService {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  specialistId String
  specialist   User   @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([specialistId, serviceId])
  @@index([specialistId])
  @@index([serviceId])
}

model SpecialistWarehouse {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  specialistId String
  specialist   User   @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([specialistId, warehouseId])
  @@index([specialistId])
  @@index([warehouseId])
}

// Tygodniowy wzorzec pracy specjalisty — dni tygodnia i godziny,
// w których pracownik jest zazwyczaj dostępny.
model SpecialistWorkDay {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specialistId String
  specialist   User   @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  weekday   Int // 0 = poniedziałek ... 6 = niedziela
  startTime String // np. "08:00"
  endTime   String // np. "16:00"

  @@unique([specialistId, weekday])
  @@index([specialistId])
}

// Wyjątki od grafiku: całe dni wolne albo wolne pojedyncze godziny w danym dniu.
model SpecialistTimeOff {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  specialistId String
  specialist   User   @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  date      DateTime // dzień, którego dotyczy wolne (godzina 00:00)
  allDay    Boolean  @default(true)
  startTime String? // np. "10:00" — tylko gdy allDay = false
  endTime   String? // np. "13:00" — tylko gdy allDay = false
  note      String?

  @@index([specialistId, date])
}

model Product {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category        ProductCategory
  name            String
  sku             String?
  ean             String?
  unit            UnitType        @default(UNIT)
  manufacturer    String?
  catalogCategory String?

  purchasePrice Int? // grosze
  salePrice     Int? // grosze
  isActive      Boolean @default(true)

  stocks             Stock[]
  lots               ProductLot[]
  consumptions       Consumption[]
  saleItems          RetailSaleItem[]
  serviceSuggestions ServiceSuggestedProduct[]

  @@index([category])
  @@index([name])
  @@index([sku])
  @@index([ean])
  @@index([manufacturer])
  @@index([catalogCategory])
}

model Warehouse {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  parentId String?
  parent   Warehouse?  @relation("WarehouseTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Warehouse[] @relation("WarehouseTree")

  stocks           Stock[]
  lots             ProductLot[]
  consumptions     Consumption[]
  specialistAccess SpecialistWarehouse[]

  @@index([parentId])
  @@index([name])
}

model Stock {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  quantity Decimal @default(0) @db.Decimal(14, 2)

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@index([productId])
}

model ProductLot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  batchNumber   String
  expiryDate    DateTime?
  quantity      Decimal   @default(0) @db.Decimal(14, 2)
  purchasePrice Int?
  salePrice     Int?
  status        String?
  location      String?
  note          String?

  @@index([productId])
  @@index([warehouseId])
  @@index([expiryDate])
  @@index([batchNumber])
}

model Appointment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  specialistId String
  specialist   User   @relation("AppointmentSpecialist", fields: [specialistId], references: [id], onDelete: Restrict)

  serviceId         String
  service           Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  customServiceName String?

  startsAt DateTime
  endsAt   DateTime

  status AppointmentStatus @default(SCHEDULED)

  // Decyzja recepcji/admina jest wymagana dopiero po oznaczeniu wizyty jako zakończonej.
  // Dla pozostałych statusów pole akceptacji pozostaje niewidoczne.
  approvalStatus  ApprovalStatus @default(PENDING)
  approvedAt      DateTime?
  approvedById    String?
  approvedBy      User?          @relation("AppointmentApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  // Powód odrzucenia wpisywany przez recepcję/admina przy odrzucaniu wizyty
  rejectionReason String?

  // Miękkie usunięcie: dane medyczne i rozliczeniowe pozostają w systemie,
  // a wizyta trafia do osobnej listy dostępnej dla recepcji i administratora.
  deletedAt      DateTime?
  deletedById    String?
  deletedBy      User?     @relation("AppointmentDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  deletionReason String?

  // pricing (grosze)
  priceEstimate Int?
  priceFinal    Int?

  note String?

  // Dokumentacja zabiegu: zdjęcia przed i po (data URL base64)
  photoBefore String? @db.Text
  photoAfter  String? @db.Text

  consumptions Consumption[]
  payments     Payment[]

  @@index([specialistId, startsAt])
  @@index([patientId, startsAt])
  @@index([status])
  @@index([deletedAt])
}

model Consumption {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  kind ConsumptionKind @default(APPOINTMENT)

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  specialistId String?
  specialist   User?   @relation("ConsumptionSpecialist", fields: [specialistId], references: [id], onDelete: SetNull)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  quantity Decimal  @db.Decimal(14, 2)
  unit     UnitType @default(UNIT)

  createdById String
  createdBy   User   @relation("ConsumptionCreator", fields: [createdById], references: [id], onDelete: Restrict)

  note String?

  // Workflow akceptacji: gdy specjalista zmieni sugerowaną ilość preparatu,
  // wpis trafia jako PENDING i nie jest odejmowany z magazynu do czasu akceptacji admina.
  status            ConsumptionStatus @default(APPLIED)
  suggestedQuantity Decimal?          @db.Decimal(14, 2)
  reviewedById      String?
  reviewedBy        User?             @relation("ConsumptionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?

  @@index([appointmentId])
  @@index([productId])
  @@index([createdById])
  @@index([status])
}

model RetailSale {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  soldById String
  soldBy   User   @relation("RetailSaleSeller", fields: [soldById], references: [id], onDelete: Restrict)

  items    RetailSaleItem[]
  payments Payment[]

  note String?

  @@index([soldById, createdAt])
}

model RetailSaleItem {
  id     String     @id @default(cuid())
  saleId String
  sale   RetailSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity  Decimal @db.Decimal(14, 2)
  unitPrice Int? // grosze
  total     Int? // grosze

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  method PaymentMethod
  amount Int // grosze

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  retailSaleId String?
  retailSale   RetailSale? @relation(fields: [retailSaleId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([retailSaleId])
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  actorId String
  actor   User   @relation(fields: [actorId], references: [id], onDelete: Cascade)

  action   String
  entity   String
  entityId String?
  data     Json?

  @@index([actorId, createdAt])
  @@index([entity, createdAt])
}
